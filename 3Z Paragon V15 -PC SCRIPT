--// Apply FPS Boost
local function ApplyFPSBoost(level)
    if not level or not FPSPresets[level] then
        warn("Invalid FPS Boost level:", level)
        return
    end
    
    local preset = FPSPresets[level]
    Settings.FPSBoost.Level = level
    Settings.FPSBoost.Enabled = true
    
    -- Apply GameSettings (pcall for safety)
    pcall(function()
        GameSettings.GraphicsMode = preset.GraphicsMode
        GameSettings.RenderDistance = preset.RenderDistance
        GameSettings.VSync = preset.VSync
    end)
    
    -- Apply Lighting settings
    pcall(function()
        Lighting.GlobalShadows = preset.Lighting.GlobalShadows
        Lighting.Technology = preset.Lighting.Technology
        Lighting.Brightness = preset.Lighting.Brightness
        Lighting.Ambient = preset.Lighting.Ambient
    end)
    
    -- Optimize workspace (remove decorative parts)
    pcall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
                if preset.ParticleQuality == Enum.ParticleQuality.Low then
                    obj.Rate = 0
                elseif preset.ParticleQuality == Enum.ParticleQuality.Medium then
                    obj.Rate = obj.Rate * 0.5
                end
            end
            if obj:IsA("Decal") or obj:IsA("Texture") then
                if level == "Low" then
                    obj.Transparency = 1
                end
            end
        end
    end)
    
    print("[FPS Boost] Applied:", preset.Name)
    print("[FPS Boost] Description:", preset.Description)
end

--// Restore Original Settings
local function RestoreFPSBoost()
    if not Settings.FPSBoost.Enabled then return end
    
    pcall(function()
        GameSettings.GraphicsMode = OriginalFPSSettings.GraphicsMode
        GameSettings.RenderDistance = OriginalFPSSettings.RenderDistance
        GameSettings.VSync = OriginalFPSSettings.VSync
    end)
    
    pcall(function()
        Lighting.GlobalShadows = OriginalFPSSettings.GlobalShadows
        Lighting.Technology = OriginalFPSSettings.Technology
        Lighting.Brightness = OriginalFPSSettings.Brightness
        Lighting.Ambient = OriginalFPSSettings.Ambient
    end)
    
    Settings.FPSBoost.Enabled = false
    print("[FPS Boost] Restored to original settings")
end

