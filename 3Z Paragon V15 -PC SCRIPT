    local function ApplyFOV(value)
        local num = tonumber(value)
        if not num then
            InputBox.Text = ""
            InputBox.PlaceholderText = "Numbers only!"
            return false
        end
        
        num = math.clamp(math.floor(num), 60, 175)
        Settings.FOV = num
        
        -- Update UI
        CurrentFOV.Text = tostring(num)
        InputBox.Text = ""
        InputBox.PlaceholderText = "Applied: " .. num
        
        -- Update Slider
        local fillPercent = (num - 60) / (175 - 60)
        SliderFill.Size = UDim2.new(fillPercent, 0, 1, 0)
        
        -- Update FOV Circle
        if FOVCircle then
            FOVCircle.Radius = num
        end
        
        print("[FOV] Set to:", num)
        return true
    end
    
    ApplyBtn.MouseButton1Click:Connect(function()
        ApplyFOV(InputBox.Text)
    end)
    
    InputBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            ApplyFOV(InputBox.Text)
        end
    end)
    
    -- Keyboard Shortcuts (Numpad +/-)
    UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.KeypadPlus then
            ApplyFOV(Settings.FOV + 5)
        elseif input.KeyCode == Enum.KeyCode.KeypadMinus then
            ApplyFOV(Settings.FOV - 5)
        end
    end)
    
    return FOVFrame
end

--// Main Loop
RunService.RenderStepped:Connect(function()
    if not ScriptEnabled then return end
    
    if FOVCircle then
        local viewportSize = Camera and Camera.ViewportSize
        if viewportSize and viewportSize.X > 0 and viewportSize.Y > 0 then
            FOVCircle.Position = Vector2.new(viewportSize.X/2, viewportSize.Y/2)
            FOVCircle.Radius = Settings.FOV
            
            local focused = nil
            pcall(function() focused = UIS:GetFocusedTextBox() end)
            FOVCircle.Visible = Settings.Enabled and Settings.ShowFOV and not focused
        end
    end
    
    local toCleanup = {}
    for player, vis in pairs(ESPObjects) do
        if not player or typeof(player) ~= "Instance" or not player.Parent then
            SetVisibility(vis, false)
            table.insert(toCleanup, player)
        else
            UpdateESP(player, vis)
        end
    end
    for _, player in ipairs(toCleanup) do Cleanup(player) end
    
    if Settings.Enabled then
        local focused = nil
        pcall(function() focused = UIS:GetFocusedTextBox() end)
        if not focused then
            local target = GetBestTarget()
            if target and target.Character then
                local head = target.Character:FindFirstChild("Head")
                local hrp = target.Character:FindFirstChild("HumanoidRootPart")
                if head and hrp then
                    local headPos = head.Position
                    local hrpPos = hrp.Position
                    if headPos and hrpPos then
                        local distance = (headPos - Camera.CFrame.Position).Magnitude
                        local smooth = CalculateSmoothing(distance)
                        local targetPos = headPos
                        local velocity = nil
                        pcall(function()
                            if hrp:IsA("BasePart") then
                                velocity = hrp.AssemblyLinearVelocity
                            end
                        end)
                        if velocity and typeof(velocity) == "Vector3" and velocity.Magnitude > 0 then
                            targetPos = targetPos + (velocity * Settings.Prediction)
                        end
                        local camPos = Camera.CFrame.Position
                        if camPos and targetPos then
                            local targetCF = CFrame.new(camPos, targetPos)
                            Camera.CFrame = Camera.CFrame:Lerp(targetCF, smooth)
                        end
                    end
                end
            end
        end
    end
end)

