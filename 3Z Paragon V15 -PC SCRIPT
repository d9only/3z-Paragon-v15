local function InitSkeleton(vis)
    if not vis or type(vis) ~= "table" then return end
    if not vis.Skeleton then vis.Skeleton = {} end
    for _, conn in ipairs(SkeletonConnections) do
        local line = SafeDrawing("Line", {Thickness = 1, Color = Color3.fromRGB(255, 255, 255), ZIndex = 2})
        if line then
            vis.Skeleton[conn[1] .. "_" .. conn[2]] = line
        end
    end
end

local function SetVisibility(vis, state)
    if not vis or type(vis) ~= "table" then return end
    for key, obj in pairs(vis) do
        if key == "Skeleton" and type(obj) == "table" then
            for _, line in pairs(obj) do
                if line and line.Visible ~= nil then line.Visible = state end
            end
        elseif obj and obj.Visible ~= nil then
            obj.Visible = state
        end
    end
end

local function UpdateESP(player, vis)
    if not player or typeof(player) ~= "Instance" then return end
    if not vis or type(vis) ~= "table" then return end
    local char = player.Character
    if not IsTargetValid(player, char) or not Settings.Enabled then
        SetVisibility(vis, false)
        return
    end
    local focusedTextBox = nil
    pcall(function() focusedTextBox = UIS:GetFocusedTextBox() end)
    if focusedTextBox then
        SetVisibility(vis, false)
        return
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then
        SetVisibility(vis, false)
        return
    end
    local posX, posY, posZ, onScreen = WorldToViewportSafe(hrp.Position)
    if not onScreen or not posX or not posY or not posZ or posZ <= 0 then
        SetVisibility(vis, false)
        return
    end
    local distance = posZ
    local sizeX = math.clamp(2500 / distance, 20, 200)
    local sizeY = math.clamp(3500 / distance, 30, 280)
    local topLeft = Vector2.new(posX - sizeX/2, posY - sizeY/2)
    local bottomRight = Vector2.new(posX + sizeX/2, posY + sizeY/2)
    
    -- Box
    if Settings.Visuals.Boxes and vis.Box then
        vis.Box.Size = Vector2.new(sizeX, sizeY)
        vis.Box.Position = topLeft
        vis.Box.Visible = true
        if Settings.Visuals.Outlines and vis.BoxOutline then
            vis.BoxOutline.Size = Vector2.new(sizeX + 2, sizeY + 2)
            vis.BoxOutline.Position = Vector2.new(topLeft.X - 1, topLeft.Y - 1)
            vis.BoxOutline.Visible = true
        elseif vis.BoxOutline then
            vis.BoxOutline.Visible = false
        end
    else
        if vis.Box then vis.Box.Visible = false end
        if vis.BoxOutline then vis.BoxOutline.Visible = false end
    end
    
    -- Health
    if Settings.Visuals.HealthBar then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid and vis.HealthBar and vis.HealthBarOutline then
            local maxHealth = humanoid.MaxHealth
            if maxHealth and maxHealth > 0 then
                local healthPercent = math.clamp(humanoid.Health / maxHealth, 0, 1)
                local barHeight = sizeY * healthPercent
                local barX = topLeft.X - 8
                vis.HealthBarOutline.From = Vector2.new(barX, topLeft.Y)
                vis.HealthBarOutline.To = Vector2.new(barX, bottomRight.Y)
                vis.HealthBarOutline.Visible = true
                vis.HealthBar.From = Vector2.new(barX, bottomRight.Y)
                vis.HealthBar.To = Vector2.new(barX, bottomRight.Y - barHeight)
                vis.HealthBar.Color = Color3.fromHSV(healthPercent * 0.3, 1, 1)
                vis.HealthBar.Visible = true
            end
        end
    else
        if vis.HealthBar then vis.HealthBar.Visible = false end
        if vis.HealthBarOutline then vis.HealthBarOutline.Visible = false end
    end
    
    -- Name
    if Settings.Visuals.Names and vis.Name then
        local playerName = player.Name
        if playerName then
            vis.Name.Position = Vector2.new(posX, topLeft.Y - 18)
            vis.Name.Text = tostring(playerName)
            vis.Name.Visible = true
        end
    elseif vis.Name then
        vis.Name.Visible = false
    end
    
    -- Distance
    if Settings.Visuals.Distance and vis.Distance then
        vis.Distance.Position = Vector2.new(posX, bottomRight.Y + 4)
        vis.Distance.Text = string.format("[%dm]", math.floor(distance))
        vis.Distance.Visible = true
    elseif vis.Distance then
        vis.Distance.Visible = false
    end
    
    -- Skeleton
    if Settings.Visuals.Skeletons then
        local charType = GetCharacterType(char)
        if charType and BoneMap[charType] then
            local map = BoneMap[charType]
            for _, conn in ipairs(SkeletonConnections) do
                local line = vis.Skeleton[conn[1] .. "_" .. conn[2]]
                if line then
                    local part1Name = map[conn[1]]
                    local part2Name = map[conn[2]]
                    if part1Name and part2Name then
                        local part1 = char:FindFirstChild(part1Name)
                        local part2 = char:FindFirstChild(part2Name)
                        if part1 and part2 then
                            local x1, y1, _, v1 = WorldToViewportSafe(part1.Position)
                            local x2, y2, _, v2 = WorldToViewportSafe(part2.Position)
                            if v1 and v2 and x1 and x2 and y1 and y2 then
                                line.From = Vector2.new(x1, y1)
                                line.To = Vector2.new(x2, y2)
                                line.Visible = true
                            else
                                line.Visible = false
                            end
                        else
                            line.Visible = false
                        end
                    end
                end
            end
        end
    else
        for _, line in pairs(vis.Skeleton or {}) do
            if line then line.Visible = false end
        end
    end
end

--// Aimbot
local function GetBestTarget()
    if not Camera then return nil end
    local bestTarget = nil
    local closestFOV = Settings.FOV
    local viewportSize = Camera.ViewportSize
    if not viewportSize or viewportSize.X <= 0 or viewportSize.Y <= 0 then return nil end
    local screenCenter = Vector2.new(viewportSize.X/2, viewportSize.Y/2)
    for _, player in ipairs(Players:GetPlayers()) do
        if not player or typeof(player) ~= "Instance" then continue end
        if not IsTargetValid(player, player.Character) then continue end
        local head = player.Character:FindFirstChild("Head")
        if not head then continue end
        local posX, posY, _, onScreen = WorldToViewportSafe(head.Position)
        if not onScreen or not posX or not posY then continue end
        local dist = (Vector2.new(posX, posY) - screenCenter).Magnitude
        if dist > closestFOV then continue end
        if not IsVisible(head.Position, player.Character) then continue end
        closestFOV = dist
        bestTarget = player
    end
    return bestTarget
end

--// Player Management
local function OnPlayerAdded(player)
    if not player or typeof(player) ~= "Instance" or player == LocalPlayer then return end
    Cleanup(player)
    local function setupCharacter(char)
        task.wait(0.5)
        if not player or not player.Parent then return end
        if not char or not char.Parent then return end
        Cleanup(player)
        local vis = CreateESPObjects()
        if vis then
            InitSkeleton(vis)
            ESPObjects[player] = vis
        end
    end
    if player.Character then
        task.spawn(function() setupCharacter(player.Character) end)
    end
    local charAddedConn = nil
    local charRemovingConn = nil
    pcall(function()
        charAddedConn = player.CharacterAdded:Connect(setupCharacter)
        charRemovingConn = player.CharacterRemoving:Connect(function() Cleanup(player) end)
    end)
    PlayerConnections[player] = {charAddedConn, charRemovingConn}
end

