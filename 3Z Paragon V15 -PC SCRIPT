local function SafeDrawing(Type, Props)
    if not Drawing or not Type then return nil end
    local success, obj = pcall(function() return Drawing.new(Type) end)
    if not success or not obj then return nil end
    if Props and typeof(Props) == "table" then
        for k, v in pairs(Props) do
            pcall(function() obj[k] = v end)
        end
    end
    return obj
end

