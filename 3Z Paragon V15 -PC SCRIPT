            pcall(function() LoginGui:Destroy() end)
            Whitelisted = true
        else
            attemptCount += 1
            AttemptsLabel.Text = "Attempts: " .. attemptCount .. " / " .. Settings.Security.MaxAttempts
            Box.Text = ""
            ShakeUI()
            UpdateStatus("Invalid key!")
            if attemptCount >= Settings.Security.MaxAttempts then
                isLocked = true
                Btn.BackgroundColor3 = Color3.fromRGB(100, 30, 30)
                Btn.Text = "LOCKED"
                UpdateStatus("Too many attempts!", Color3.fromRGB(255, 50, 50))
                task.delay(Settings.Security.LockoutTime, function()
                    if not Main or not Main.Parent then return end
                    isLocked = false
                    attemptCount = 0
                    Btn.BackgroundColor3 = Color3.fromRGB(40, 60, 150)
                    Btn.Text = "AUTHENTICATE"
                    AttemptsLabel.Text = "Attempts: 0 / " .. Settings.Security.MaxAttempts
                    UpdateStatus("")
                end)
            end
        end
    end
    
    Btn.MouseButton1Click:Connect(AttemptLogin)
    Box.FocusLost:Connect(function(enterPressed)
        if enterPressed then AttemptLogin() end
    end)
end

