--// Core Functions
local function WorldToViewportSafe(pos)
    if not pos or typeof(pos) ~= "Vector3" then return nil, nil, nil, false end
    if not Camera then return nil, nil, nil, false end
    local success, result = pcall(function() return Camera:WorldToViewportPoint(pos) end)
    if success and result and typeof(result) == "Vector3" then
        return result.X, result.Y, result.Z, true
    end
    return nil, nil, nil, false
end

local function IsTargetValid(player, character)
    if not player or player == LocalPlayer then return false end
    if not character or typeof(character) ~= "Instance" then return false end
    if not character.Parent then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    if Settings.TeamCheck then
        local success, sameTeam = pcall(function() return player.Team == LocalPlayer.Team end)
        if success and sameTeam then return false end
    end
    return true
end

local function IsVisible(targetPos, targetChar)
    if not targetPos or typeof(targetPos) ~= "Vector3" then return false end
    if not targetChar or typeof(targetChar) ~= "Instance" then return false end
    if not Camera then return false end
    local origin = Camera.CFrame.Position
    local direction = targetPos - origin
    local distance = direction.Magnitude
    if distance > Settings.MaxDistance or distance <= 0 then return false end
    direction = direction.Unit * distance
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, targetChar}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.IgnoreWater = true
    local success, result = pcall(function() return workspace:Raycast(origin, direction, params) end)
    if not success then return false end
    return result == nil
end

local function CalculateSmoothing(distance)
    if not distance or typeof(distance) ~= "number" or distance <= 0 then
        return Settings.Smoothing
    end
    local factor = math.clamp(distance / Settings.MaxDistance, 0, 1)
    return math.clamp(Settings.Smoothing * (1 - factor) * 3, 0.02, 0.3)
end

local function GetCharacterType(char)
    if not char or typeof(char) ~= "Instance" then return nil end
    if char:FindFirstChild("UpperTorso") then return "R15"
    elseif char:FindFirstChild("Torso") then return "R6"
    end
    return nil
end

--// Cleanup
local function Cleanup(player)
    if not player or typeof(player) ~= "Instance" then return end
    if PlayerConnections[player] then
        for _, conn in ipairs(PlayerConnections[player]) do
            if conn and typeof(conn) == "RBXScriptConnection" then
                pcall(function() conn:Disconnect() end)
            end
        end
        PlayerConnections[player] = nil
    end
    if ESPObjects[player] then
        for key, obj in pairs(ESPObjects[player]) do
            if key == "Skeleton" and type(obj) == "table" then
                for _, line in pairs(obj) do
                    if line and typeof(line) == "table" and line.Remove then
                        pcall(function() line:Remove() end)
                    end
                end
            elseif obj and typeof(obj) == "table" and obj.Remove then
                pcall(function() obj:Remove() end)
            end
        end
        ESPObjects[player] = nil
    end
end

